# Next.js Environment Variables Config
# Copy this file to .env.local and fill in the values from your Supabase and Gemini Dashboards.

# =========================================================================
# Supabase Cloud Configuration
# Get these from: Project Settings -> API in your Supabase Dashboard
# =========================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# REQUIRED for store checkout (mark/rollback) AND print (settle points + status simulator).
# Missing this key → POST /api/orders and /api/print-jobs return HTTP 500 (fail-closed).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =========================================================================
# AI Integration Configuration
# Get your free Gemini API Key from: https://aistudio.google.com/
# =========================================================================
GEMINI_API_KEY=your-gemini-api-key

# =========================================================================
# Application Configuration
# =========================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
